# ============================================================
# SUPABASE
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# RESEND (envio de e-mails)
# ============================================================
RESEND_API_KEY=re_your-api-key-here
RESEND_FROM_EMAIL=convites@suaconsultoria.com.br

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Rebalanceador

# ============================================================
# PLUGGY (Open Finance / agregação financeira)
# Dashboard: https://dashboard.pluggy.ai
# ============================================================
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
# Segredo usado para validar a assinatura HMAC dos webhooks da Pluggy.
# Gere uma string aleatória forte (ex.: openssl rand -hex 32) e
# configure o mesmo valor no painel da Pluggy em Webhooks → Secret.
PLUGGY_WEBHOOK_SECRET=
# Segredo (HS256) usado para assinar os JWTs do link /conectar/[token]
# que o consultor envia ao cliente final. Gere com openssl rand -hex 32.
PLUGGY_INVITE_SECRET=
# Inclui conectores de sandbox no widget (true em dev, vazio em produção).
NEXT_PUBLIC_PLUGGY_INCLUDE_SANDBOX=true

# ============================================================
# SENTRY
# ============================================================
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_OTLP_TRACES_URL=""
SENTRY_PROJECT=""
SENTRY_PUBLIC_KEY=""
SENTRY_VERCEL_LOG_DRAIN_URL=""
SENTRY_AUTH_TOKEN=""
